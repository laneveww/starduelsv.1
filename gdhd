        local function scytheApplySky(mode)
            _scytheSaveLighting(); _scytheClearSky()
            local p=_SCYTHE_SKY_PRESETS[mode]
            if not p or p.kind=="off" then
                if _scytheOrigLight then
                    pcall(function() Lighting.ClockTime=_scytheOrigLight.ClockTime end)
                    pcall(function() Lighting.OutdoorAmbient=_scytheOrigLight.OutdoorAmbient end)
                    pcall(function() Lighting.Ambient=_scytheOrigLight.Ambient end)
                    pcall(function() Lighting.Brightness=_scytheOrigLight.Brightness end)
                    pcall(function() Lighting.FogStart=_scytheOrigLight.FogStart end)
                    pcall(function() Lighting.FogEnd=_scytheOrigLight.FogEnd end)
                    pcall(function() Lighting.GlobalShadows=_scytheOrigLight.GlobalShadows end)
                    for _,c in ipairs(_scytheOrigLight.skyChildren) do c:Clone().Parent=Lighting end
                    local t=workspace:FindFirstChildOfClass("Terrain"); if t then for _,c in ipairs(_scytheOrigLight.cloudChildren) do c:Clone().Parent=t end end
