local function showRagdollTimer(char)
        if _ragdollTimerActive then return end
        _ragdollTimerActive = true
        task.spawn(function()
                local TS3 = game:GetService("TweenService")

                -- Find the head to attach the billboard to
                local head = char and char:FindFirstChild("Head")
                if not head then _ragdollTimerActive = false; return end

                -- BillboardGui above the player's head
                local bb = Instance.new("BillboardGui")
                bb.Name = "RagdollTimerBB"
                bb.Adornee = head
                bb.Size = UDim2.new(0, 120, 0, 60)
                bb.StudsOffset = Vector3.new(0, 3.5, 0)
                bb.AlwaysOnTop = true
                bb.ResetOnSpawn = false
                pcall(function() bb.Parent = game:GetService("CoreGui") end)
                if not bb.Parent then bb.Parent = LP:WaitForChild("PlayerGui") end

                -- Main label (shows number / READY!)
                local lbl = Instance.new("TextLabel", bb)
                lbl.Size = UDim2.new(1, 0, 0.6, 0)
                lbl.Position = UDim2.new(0, 0, 0.4, 0)
                lbl.BackgroundTransparency = 1
                lbl.Text = "3"
                lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
                lbl.Font = Enum.Font.GothamBlack
                lbl.TextSize = 36
                lbl.TextXAlignment = Enum.TextXAlignment.Center
                lbl.TextScaled = false
                local numStroke = Instance.new("UIStroke", lbl)
                numStroke.Color = Color3.fromRGB(0, 0, 0)
                numStroke.Thickness = 3

                -- Small "RAGDOLL TIMER" label above the number
                local titleLbl = Instance.new("TextLabel", bb)
                titleLbl.Size = UDim2.new(1, 0, 0.4, 0)
                titleLbl.Position = UDim2.new(0, 0, 0, 0)
                titleLbl.BackgroundTransparency = 1
                titleLbl.Text = "RAGDOLL TIMER"
                titleLbl.TextColor3 = Color3.fromRGB(220, 220, 220)
                titleLbl.Font = Enum.Font.GothamBold
                titleLbl.TextSize = 11
                titleLbl.TextXAlignment = Enum.TextXAlignment.Center
                local titleStroke = Instance.new("UIStroke", titleLbl)
                titleStroke.Color = Color3.fromRGB(0, 0, 0)
                titleStroke.Thickness = 2

                -- Countdown 3 → 2 → 1 (each number pulses)
                for i = 3, 1, -1 do
                        lbl.Text = tostring(i)
                        lbl.TextTransparency = 0
                        lbl.TextSize = 42
                        TS3:Create(lbl, TweenInfo.new(0.18, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
                                {TextSize = 32}):Play()
