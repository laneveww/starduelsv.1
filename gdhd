                local spawn=prompt.Parent and prompt.Parent.Parent
                local function getSpawnDist()
                        local char=LP.Character;local root=char and char:FindFirstChild("HumanoidRootPart")
                        if not root or not spawn or not spawn:IsA("BasePart") then return 0 end
                        return (spawn.Position-root.Position).Magnitude
                end
                local alreadyClose=getSpawnDist()<=Steal.StealRange
                local fired=false
                while (tick()-stealStartTime)<Steal.HoldMax do
                        if not prompt.Parent then break end
                        if getSpawnDist()<=Steal.StealRange then
                                if not alreadyClose then task.wait(0.3) end
                                for _,fn in ipairs(data.trigger) do task.spawn(fn) end
                                fired=true; break
                        end
                        task.wait()
                end
                if not fired then
                        for _,fn in ipairs(data.trigger) do task.spawn(fn) end
                end
