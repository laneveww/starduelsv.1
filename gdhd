        beamSparkles.BackgroundTransparency = 0.75

        local beamTween = TweenService:Create(lightBeam, TweenInfo.new(0.8, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), {
                Position = UDim2.new(1, 20, 0.5, 0)
        })
