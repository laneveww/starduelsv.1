                end

                -- READY!
                lbl.Text = "READY!"
                lbl.TextSize = 28
                lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
                numStroke.Thickness = 4
                TS3:Create(lbl, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
                        {TextSize = 22}):Play()
                task.wait(1.2)

                -- Fade out
                TS3:Create(lbl,      TweenInfo.new(0.3), {TextTransparency = 1}):Play()
                TS3:Create(titleLbl, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
                task.wait(0.35)
                pcall(function() bb:Destroy() end)
                _ragdollTimerActive = false
        end)
end

