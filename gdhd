                numStroke.Thickness = 3

                -- Small "RAGDOLL TIMER" label above the number
                local titleLbl = Instance.new("TextLabel", bb)
                titleLbl.Size = UDim2.new(1, 0, 0.4, 0)
                titleLbl.Position = UDim2.new(0, 0, 0, 0)
