                local s = ""
                for c in original:gmatch(".") do
                        s = s .. (math.random() < 0.35 and glitchChars[math.random(#glitchChars)] or c)
                end
                lbl.Text = s
                task.wait(0.03)
        end
        if not introSkipped then
                lbl.Text = original
        end
