local function playIntroAnimation()
    local localPlayer = game.Players.LocalPlayer
    local playerGui = localPlayer:FindFirstChild('PlayerGui')
    if not playerGui then return end
    
    -- First Soul Animation Screen
    local screenGui = Instance.new('ScreenGui')
    screenGui.IgnoreGuiInset = true
    screenGui.Parent = playerGui
    
    local imageLabel = Instance.new('ImageLabel')
    imageLabel.Parent = screenGui
    imageLabel.Size = UDim2.new(0, 0, 0, 0)
    imageLabel.Position = UDim2.new(0.5, 0, 0.5, 0)
    imageLabel.AnchorPoint = Vector2.new(0.5, 0.5)
    imageLabel.BackgroundTransparency = 1
    imageLabel.Image = 'rbxassetid://13879097036'
    imageLabel.ScaleType = Enum.ScaleType.Fit
    imageLabel.BorderSizePixel = 0
    imageLabel.ImageTransparency = 0
    
    -- Rotation and size animation variables
    local u1 = 1          -- Rotation duration
    local u2 = 10         -- Rotation speed
    local u3 = 0.7        -- Size grow duration
    local u4 = 0.5        -- Transparency start
    
    -- Rotation animation
    task.spawn(function()
        local v5 = tick()
        while tick() - v5 < u1 do
            imageLabel.Rotation = imageLabel.Rotation + u2
            task.wait(0.01)
        end
    end)
    
    -- Size and transparency animation
    task.spawn(function()
        local v6 = tick()
        while tick() - v6 < u3 do
            local v7 = (tick() - v6) / u3 * 1.2
            imageLabel.Size = UDim2.new(v7, 0, v7, 0)
            if u4 <= v7 then
                local v8 = (v7 - u4) / (1.2 - u4)
                imageLabel.ImageTransparency = math.clamp(v8, 0, 1)
            end
            task.wait(0.01)
        end
        imageLabel.Size = UDim2.new(1.2, 0, 1.2, 0)
        imageLabel.ImageTransparency = 1
    end)
    
    -- Destroy first screen
    task.delay(u1, function()
        screenGui:Destroy()
    end)
    
    -- Second Screen with purple gradient and logo
    local screenGui2 = Instance.new('ScreenGui')
    screenGui2.IgnoreGuiInset = true
    screenGui2.ResetOnSpawn = false
    screenGui2.Parent = playerGui
    
    -- Purple gradient background
    local frame = Instance.new('Frame')
    frame.Parent = screenGui2
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.BackgroundColor3 = Color3.fromRGB(120, 0, 255)
    frame.BackgroundTransparency = 0.4
    frame.ZIndex = 0
    
    local uIGradient = Instance.new('UIGradient')
    uIGradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(150, 50, 255)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(80, 0, 180)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(150, 50, 255))
    })
    uIGradient.Rotation = 0
    uIGradient.Parent = frame
    
    -- Rotating gradient
    task.spawn(function()
        while frame.Parent do
            uIGradient.Rotation = (uIGradient.Rotation + 1) % 360
            task.wait(0.02)
        end
    end)
    
    -- Second soul image
    local imageLabel2 = Instance.new('ImageLabel')
    imageLabel2.Parent = screenGui2
    imageLabel2.Size = UDim2.new(0, 0, 0, 0)
    imageLabel2.Position = UDim2.new(0.5, 0, 0.5, 0)
    imageLabel2.AnchorPoint = Vector2.new(0.5, 0.5)
    imageLabel2.BackgroundTransparency = 1
    imageLabel2.Image = 'rbxassetid://13879097036'
    imageLabel2.ScaleType = Enum.ScaleType.Fit
    imageLabel2.BorderSizePixel = 0
    imageLabel2.ImageTransparency = 0
    
    -- Background music
    local sound2 = Instance.new('Sound')
    sound2.SoundId = 'rbxassetid://76650356472656'
    sound2.Volume = 2
    sound2.TimePosition = 3
    sound2.Parent = playerGui
    sound2:Play()
    
    -- Fade out music after 8 seconds
    task.delay(8, function()
        local tweenService = game:GetService("TweenService")
        tweenService:Create(sound2, TweenInfo.new(1), {Volume = 0}):Play()
        task.wait(1)
        sound2:Stop()
    end)
    
    -- Second screen animation variables
    local u9 = 4          -- Total duration
    local u10 = 2         -- Image grow duration
    local u11 = 0         -- Rotation speed
    local u12 = 12        -- Max rotation speed
    local u13 = 0.2       -- Rotation change rate
    local u14 = 1.5       -- Fade out duration
    
    -- Accelerating rotation
    task.spawn(function()
        local v15 = tick()
        while imageLabel2.Parent do
            if tick() - v15 >= u9 - u14 then
                u11 = math.max(u11 - u13, 0)
            else
                u11 = math.min(u11 + u13, u12)
            end
            imageLabel2.Rotation = imageLabel2.Rotation + u11
            task.wait(0.01)
        end
    end)
    
    -- Image size grow
    task.spawn(function()
        local v16 = tick()
        while tick() - v16 < u10 do
            local v17 = (tick() - v16) / u10
            imageLabel2.Size = UDim2.new(v17, 0, v17, 0)
            task.wait(0.01)
        end
        imageLabel2.Size = UDim2.new(1, 0, 1, 0)
    end)
    
    -- Fade out animation
    task.spawn(function()
        task.wait(u9 - u14)
        local u142 = u14
        local v18 = tick()
        while tick() - v18 < u142 do
            local v19 = (tick() - v18) / u142
            imageLabel2.ImageTransparency = v19
            frame.BackgroundTransparency = 0.4 + v19 * 0.6
            uIGradient.Transparency = NumberSequence.new(v19)
            task.wait(0.01)
        end
    end)
    
    -- Text animation after soul fades
    task.delay(u9, function()
        local textLabel = Instance.new("TextLabel")
        textLabel.Parent = screenGui2
        textLabel.Size = UDim2.new(1, 0, 1, 0)
        textLabel.BackgroundTransparency = 1
        textLabel.Text = "STAR DUELS"
        textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)  -- PUTI NA
        textLabel.Font = Enum.Font.GothamBlack
        textLabel.TextSize = 1
        textLabel.TextTransparency = 1
        
        -- Black stroke border
        local uiStroke = Instance.new("UIStroke")
        uiStroke.Parent = textLabel
        uiStroke.Color = Color3.fromRGB(0, 0, 0)
        uiStroke.Thickness = 3
        uiStroke.Transparency = 1
        
        -- Remove previous image
        imageLabel2:Destroy()
        
        -- Text fade in animation
        local tweenService = game:GetService("TweenService")
        tweenService:Create(textLabel, TweenInfo.new(1.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
            TextSize = 80,
            TextTransparency = 0
        }):Play()
        tweenService:Create(uiStroke, TweenInfo.new(1.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
            Transparency = 0
        }):Play()
        
        task.wait(2.5)
        
        -- Text fade out animation
        tweenService:Create(textLabel, TweenInfo.new(1, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            TextTransparency = 1,
            TextSize = 120
        }):Play()
        tweenService:Create(uiStroke, TweenInfo.new(1, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            Transparency = 1
        }):Play()
        
        task.wait(1)
        screenGui2:Destroy()
    end)
end

