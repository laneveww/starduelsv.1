local function getBatTP()
    local char = LP.Character
    if not char then return nil end
    -- Hanapin ang anumang tool na may "bat" o "slap" sa pangalan (case-insensitive)
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") then
            local name = tool.Name:lower()
            if name:find("bat") or name:find("slap") then
                return tool
            end
        end
    end
    -- Hanapin sa backpack at i-equip
    local bp = LP:FindFirstChild("Backpack")
    if bp then
        for _, tool in ipairs(bp:GetChildren()) do
            if tool:IsA("Tool") then
                local name = tool.Name:lower()
                if name:find("bat") or name:find("slap") then
                    tool.Parent = char  -- i-equip
                    return tool
                end
            end
        end
    end
    return nil
end

local function swingBatTP()
    local bat = getBatTP()
    if bat then
        pcall(function()
            bat:Activate()
            local ev = bat:FindFirstChildWhichIsA("RemoteEvent")
            if ev then ev:FireServer() end
        end)
    end
end

local function getClosestPlayerTP()
    if not hrp then return nil, math.huge end
    local closest, minDist = nil, math.huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LP and plr.Character then
            local tr = plr.Character:FindFirstChild("HumanoidRootPart")
            if tr then
                local d = (hrp.Position - tr.Position).Magnitude
                if d < minDist then
                    minDist = d
                    closest = tr
                end
            end
        end
    end
    return closest, minDist
end

local function startTPBat()
    if tpBatConn then return end
    tpBatEnabled = true
    if stackBtnRefs.tpBat then stackBtnRefs.tpBat.setOn(true) end

    -- I-save ang kasalukuyang estado ng auto features at i-off ang mga ito
    _prevAutoStates.autoLeft = State.autoLeftEnabled
    _prevAutoStates.autoRight = State.autoRightEnabled
    _prevAutoStates.aimbot = State.batAimbotToggled

    if State.autoLeftEnabled then
        setAutoLeft(false)  -- use the new mutual exclusion function
    end
    if State.autoRightEnabled then
        setAutoRight(false)
    end
    if State.batAimbotToggled then
        State.batAimbotToggled = false
        stopBatAimbot()
        if stackBtnRefs.aimbot then stackBtnRefs.aimbot.setOn(false) end
    end

    tpBatConn = RunService.Heartbeat:Connect(function()
        if not tpBatEnabled then
            if tpBatConn then tpBatConn:Disconnect(); tpBatConn = nil end
            return
        end
        local char = LP.Character
        if not char then return end
        hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        local STAR, dist = getClosestPlayerTP()
        if STAR and dist < 50 then
            -- Envy-style teleport
            if sethiddenproperty then
                sethiddenproperty(hrp, "PhysicsRepRootPart", STAR)
            end
            local STARPos = STAR.Position + Vector3.new(0, 0.9, 0)
            if (hrp.Position - STARPos).Magnitude > 8 then
                hrp.CFrame = CFrame.new(STARPos)
            end
            -- Point camera at STAR
            local cam = workspace.CurrentCamera
            if cam then
                cam.CFrame = CFrame.new(cam.CFrame.Position, STAR.Position)
            end
            -- Swing bat
            swingBatTP()
        end
    end)
end

local function stopTPBat()
    tpBatEnabled = false
    if tpBatConn then
        tpBatConn:Disconnect()
        tpBatConn = nil
    end
    if stackBtnRefs.tpBat then stackBtnRefs.tpBat.setOn(false) end

    -- I-restore ang mga dating estado ng auto features
    if _prevAutoStates.autoLeft and not State.autoLeftEnabled then
        setAutoLeft(true)
    end
    if _prevAutoStates.autoRight and not State.autoRightEnabled then
        setAutoRight(true)
    end
    if _prevAutoStates.aimbot and not State.batAimbotToggled then
        State.batAimbotToggled = true
        startBatAimbot()
        if stackBtnRefs.aimbot then stackBtnRefs.aimbot.setOn(true) end
    end
end

