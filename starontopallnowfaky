        local oldInfo
        oldInfo = hookfunction(dbg.info, function(...)
            local s = oldInfo(1, "s")
            -- Esconde qualquer checagem de source que envolva speed/velocity
            if s and (s:find("Packages.Synchronizer") or s:find("Packages.Net")) then
